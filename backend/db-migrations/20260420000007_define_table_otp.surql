DEFINE TABLE OVERWRITE otp TYPE NORMAL SCHEMAFULL PERMISSIONS NONE;

DEFINE FIELD OVERWRITE code ON otp TYPE string PERMISSIONS FULL;
DEFINE FIELD OVERWRITE created_at ON otp TYPE datetime READONLY VALUE $before ?? time::now() PERMISSIONS FULL;
DEFINE FIELD OVERWRITE expires_at ON otp TYPE datetime PERMISSIONS FULL;
DEFINE FIELD OVERWRITE failed_attempts ON otp TYPE int DEFAULT 0 PERMISSIONS FULL;

DEFINE INDEX OVERWRITE otp_expires_idx ON otp FIELDS expires_at CONCURRENTLY;