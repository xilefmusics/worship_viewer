DEFINE TABLE OVERWRITE like TYPE NORMAL SCHEMAFULL PERMISSIONS NONE;

DEFINE FIELD OVERWRITE created_at ON like TYPE datetime DEFAULT time::now() READONLY VALUE $before ?? $value PERMISSIONS FULL;
DEFINE FIELD OVERWRITE owner ON like TYPE record<user> ASSERT $value != NONE PERMISSIONS FULL;
DEFINE FIELD OVERWRITE song ON like TYPE record<song> ASSERT $value != NONE PERMISSIONS FULL;

DEFINE INDEX OVERWRITE like_owner_song_unique ON like FIELDS owner, song UNIQUE CONCURRENTLY;