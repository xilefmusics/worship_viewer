DEFINE TABLE OVERWRITE oidc_state TYPE NORMAL SCHEMAFULL PERMISSIONS NONE;

DEFINE FIELD OVERWRITE created_at ON oidc_state TYPE datetime READONLY VALUE $before ?? time::now() PERMISSIONS FULL;
DEFINE FIELD OVERWRITE expires_at ON oidc_state TYPE datetime PERMISSIONS FULL;
DEFINE FIELD OVERWRITE nonce ON oidc_state TYPE string PERMISSIONS FULL;
DEFINE FIELD OVERWRITE pkce_verifier ON oidc_state TYPE string PERMISSIONS FULL;
DEFINE FIELD OVERWRITE redirect_to ON oidc_state TYPE none | string PERMISSIONS FULL;

DEFINE INDEX OVERWRITE oidc_state_expires_idx ON oidc_state FIELDS expires_at CONCURRENTLY;